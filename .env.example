# =============================================================================
# Inventix ERP — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control — it is already in .gitignore.
#
# Naming convention:
#   VITE_*   → Exposed to the client bundle (Vite replaces at build time).
#              Only use for PUBLIC, non-sensitive keys (e.g. Supabase anon key).
#   No prefix → Server-side / Node.js only. Never exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Required for database, auth, realtime, and storage.
# Find these in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose — needed by the client SDK).
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anonymous/public key (safe to expose — RLS enforces data isolation).
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service-role key — NEVER expose to the client bundle.
# Used only in server-side scripts (e.g. seed scripts, Edge Functions).
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# -----------------------------------------------------------------------------
# Google Gemini AI — Required for AI Insights section.
# AI Studio automatically injects this at runtime from user secrets.
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# The public URL where this app is hosted (used for OAuth callbacks, etc.).
APP_URL="http://localhost:3000"
